  "servers": [
    {
      "url": "http://api.phpsx.org"
    }
  ],
  "methods": [
    {
      "name": "foo.bar.get",
      "description": "Returns a collection",
      "params": [],
      "result": {
        "name": "result",
        "schema": {
          "$ref": "#/components/schemas/EntryCollection"
        }
      }
    },
    {
      "name": "foo.bar.create",
      "description": "",
      "params": [
        {
          "name": "payload",
          "schema": {
            "$ref": "#/components/schemas/EntryCreate"
          }
        }
      ],
      "result": {
        "name": "result",
        "schema": {
          "$ref": "#/components/schemas/EntryMessage"
        }
      }
    },
    {
      "name": "bar.find",
      "description": "Returns a collection",
      "params": [
        {
          "name": "foo",
          "schema": {
            "type": "string"
          }
        }
      ],
      "result": {
        "name": "result",
        "schema": {
          "$ref": "#/components/schemas/EntryCollection"
        }
      }
    },
    {
      "name": "bar.put",
      "description": "",
      "params": [
        {
          "name": "payload",
          "schema": {
            "$ref": "#/components/schemas/EntryCreate"
          }
        }
      ],
      "result": {
        "name": "result",
        "schema": {
          "$ref": "#/components/schemas/EntryMessage"
        }
      }
    },
    {
      "name": "foo.baz.get",
      "description": "Returns a collection",
      "params": [
        {
          "name": "year",
          "schema": {
            "type": "string"
          }
        }
      ],
      "result": {
        "name": "result",
        "schema": {
          "$ref": "#/components/schemas/EntryCollection"
        }
      }
    },
    {
      "name": "foo.baz.create",
      "description": "",
      "params": [
        {
          "name": "payload",
          "schema": {
            "$ref": "#/components/schemas/EntryCreate"
          }
        }
      ],
      "result": {
        "name": "result",
        "schema": {
          "$ref": "#/components/schemas/EntryMessage"
        }
      }
    }
  ],
  "components": {
    "schemas": {
      "Entry": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "userId": {
            "type": "integer"
          },
          "title": {
            "type": "string"
          },
          "date": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "EntryCollection": {
        "type": "object",
        "properties": {
          "entry": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Entry"
            }
          }
        }
      },
      "EntryCreate": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "userId": {
            "type": "integer"
          },
          "title": {
            "type": "string"
          },
          "date": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "EntryMessage": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          },
          "message": {
            "type": "string"
          }
        }
      }
    }
  }
}